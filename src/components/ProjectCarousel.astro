---
import { projects } from '../data/projects.js';
---
<section class="border-b-4 border-black">
  <div class="p-6 md:p-12 border-b-4 border-black bg-black text-white flex justify-between items-end">
    <h3 class="text-5xl font-black uppercase tracking-tighter leading-none">Selected Work</h3>
    <span class="font-bold text-red-600 hidden md:block">SCROLL &rarr;</span>
  </div>
  
  <div class="flex overflow-x-auto snap-x snap-mandatory no-scrollbar border-b-4 border-black">
    {projects.map((project) => (
      <a 
        href={`/projects/${project.slug}`} 
        class="flex-shrink-0 w-[85vw] md:w-[45vw] lg:w-[33.333vw] border-r-4 border-black flex flex-col group snap-start cursor-pointer transition-none bg-white hover:bg-black hover:text-white"
      >
        <div class="aspect-video bg-gray-200 border-b-4 border-black flex items-center justify-center grayscale group-hover:grayscale-0 transition-none relative">
            <span class="font-black text-gray-400 text-xl tracking-widest group-hover:text-transparent absolute uppercase">
              [{project.slug.replace(/-/g, ' ')}]
            </span>
        </div>
        <div class="p-6 md:p-8 flex-grow flex flex-col justify-between">
          <div>
            <h4 class="text-3xl font-black uppercase tracking-tight mb-2">{project.title}</h4>
            <p class="text-lg font-bold mb-6">{project.shortDesc}</p>
          </div>
          <p class="text-sm font-black uppercase tracking-widest text-red-600">{project.techStack}</p>
        </div>
      </a>
    ))}
  </div>
</section>
